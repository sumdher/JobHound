# JobHound Backend Environment Variables
# Copy this to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jobhound:localdev@db:5432/jobhound

# ── Auth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

# ── LLM Provider: ollama | openai | anthropic | nebius ───────────────────────
LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
NEBIUS_API_KEY=
NEBIUS_MODEL=
NEBIUS_BASE_URL=

# ── Embedding Provider: ollama | openai ──────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=1536

# ── Admin / User Approval ─────────────────────────────────────────────────────
# Your email — auto-approved on first sign-in and receives approval request emails.
# Leave empty to disable approval gating (all users auto-approved, dev mode).
ADMIN_EMAIL=
# Public URL of the frontend — used to build approve/reject links in emails.
APP_URL=http://localhost:3000

# ── Resend (approval emails) ──────────────────────────────────────────────────
# Sign up free at resend.com → API Keys → create key (send-only scope).
# RESEND_FROM_EMAIL: must be a verified sender on your Resend account.
#   During dev you can use "onboarding@resend.dev" (sends only to your own email).
#   For production: verify your domain at resend.com and use noreply@yourdomain.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=JobHound <noreply@yourdomain.com>
