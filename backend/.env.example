# JobHound Backend Environment Variables
# Copy this to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jobhound:localdev@db:5432/jobhound

# ── Auth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

# ── LLM Provider: ollama | openai | anthropic | nebius ───────────────────────
LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
NEBIUS_API_KEY=
NEBIUS_MODEL=
NEBIUS_BASE_URL=

# ── Embedding Provider: ollama | openai ──────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=1536

# ── Admin / User Approval ─────────────────────────────────────────────────────
# Your email — auto-approved on first sign-in and receives approval request emails.
# Leave empty to disable approval gating (all users auto-approved, dev mode).
ADMIN_EMAIL=
# Public URL of the frontend — used to build approve/reject links in emails.
APP_URL=http://localhost:3000

# ── SMTP (for approval emails) ────────────────────────────────────────────────
# Example: Gmail with App Password (SMTP_PORT=587, STARTTLS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
