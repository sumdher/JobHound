# JobHound Frontend Environment Variables
# Copy this to .env.local and fill in your values.

# ── API ───────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL is not needed — falls back to /backend (proxied by Next.js)

# ── NextAuth ─────────────────────────────────────────────────────────────────
# NEXTAUTH_URL is intentionally not set — NextAuth auto-detects from request Host.
# In production, set this to your domain (e.g. https://jobhound.example.com).
NEXTAUTH_SECRET=change-me

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
